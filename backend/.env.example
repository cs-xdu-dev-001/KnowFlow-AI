# Runtime mode
# sqlite is easiest for local demos; mysql matches the final design.
KNOWFLOW_DB_URL=sqlite:///./data/knowflow.db
KNOWFLOW_UPLOAD_DIR=./data/uploads
# Example MySQL:
# KNOWFLOW_DB_URL=mysql+pymysql://root:123456@127.0.0.1:3306/knowflow_ai?charset=utf8mb4

# Vector backend: local or chroma
KNOWFLOW_VECTOR_BACKEND=local
KNOWFLOW_CHROMA_DIR=./data/chroma

# Used to encrypt API keys in model_config.api_key_cipher.
# Change this before using real keys.
KNOWFLOW_SECRET_KEY=change-this-dev-secret

# Public base URL used by OAuth callbacks.
KNOWFLOW_BASE_URL=http://127.0.0.1:8010
# Frontend origins allowed as OAuth return targets. Match scheme, host, and port exactly.
KNOWFLOW_OAUTH_RETURN_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# GitHub OAuth Login.
# GitHub OAuth App callback URL:
# http://127.0.0.1:8010/api/auth/oauth/github/callback
KNOWFLOW_GITHUB_CLIENT_ID=
KNOWFLOW_GITHUB_CLIENT_SECRET=

# Set to 1 only when serving HTTPS.
KNOWFLOW_COOKIE_SECURE=0
KNOWFLOW_AUTH_SESSION_TTL=604800
# Set to 1 only if you intentionally want the first signed-in user to adopt legacy rows with NULL user_id.
KNOWFLOW_ADOPT_LEGACY_DATA=0

# Retrieval defaults
KNOWFLOW_CHUNK_SIZE=800
KNOWFLOW_CHUNK_OVERLAP=120
KNOWFLOW_TOP_K=5
KNOWFLOW_RAG_SCORE_THRESHOLD=0.25
